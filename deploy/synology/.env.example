# auction self-hosted backend — 환경변수 템플릿
# cp .env.example .env  후 아래 값들 채우기.
# 비밀번호 생성:  openssl rand -base64 24   (JWT_SECRET 은 -base64 48)

# --- Postgres ---
POSTGRES_PASSWORD=

# --- PostgREST authenticator 역할 ---
# bootstrap/00_roles.sql 의 'CHANGE_ME_SAME_AS_ENV' 와 동일해야 함 (README 4장 sed 단계)
AUTHENTICATOR_PASSWORD=

# --- JWT (anon key 발급 + PostgREST 검증 공용) ---
# openssl rand -base64 48   (최소 32자)
JWT_SECRET=

# --- MinIO (사진 저장소) ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- pgAdmin (profile=admin 일 때만) ---
PGADMIN_EMAIL=admin@local
PGADMIN_PASSWORD=
