# Caddy — supabase-js 호환 경로 라우팅 (Supabase Kong 게이트웨이 대체)
#
# synology.me 는 서브도메인(api.*/files.*)을 못 만들므로(DDNS 와일드카드 미지원)
# 단일 호스트 + 경로 기반으로 분기한다:
#   /rest/v1/*  → PostgREST  (supabase-js 가 ${SUPABASE_URL}/rest/v1/<table> 로 호출)
#   /storage/*  → MinIO       (이미지 공개 GET — {bucket}/{key})
#
# TLS 는 DSM 역방향 프록시(synology.me Let's Encrypt)가 종단 → Caddy 는 평문 :80.
# LAN 내부 크롤러/dev 도 http://<NAS_IP>:8080/rest/v1/* 로 직접 들어온다.
# (이미지 업로드는 크롤러가 MinIO:9000 에 boto3 로 직접 — Caddy 안 거침.)

:80 {
	# supabase-js REST 호출 → PostgREST (prefix 제거)
	handle_path /rest/v1/* {
		reverse_proxy rest:3000
	}

	# 이미지 공개 GET → MinIO (prefix 제거 → /{bucket}/{key})
	#   예: /storage/auction-photos/B000210/2023-6292/1/01.jpg
	#       → MinIO /auction-photos/B000210/2023-6292/1/01.jpg
	handle_path /storage/* {
		reverse_proxy storage:9000
	}

	# 헬스체크
	respond /health 200

	# 그 외 경로는 명확한 404 (디버깅 편의)
	handle {
		respond "auction backend — use /rest/v1/* or /storage/*" 404
	}
}
